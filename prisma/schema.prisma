// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  content     String
  type        String   // "Notice", "Announcement", "Blog"
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdmissionForm {
  id             String   @id @default(uuid())
  studentName    String
  dateOfBirth    String
  gradeAppliedFor String
  previousSchool String?
  guardianName   String
  contactPhone   String
  status         String   @default("Pending") // "Pending", "Under Review", "Accepted", "Rejected"
  createdAt      DateTime @default(now())
}
